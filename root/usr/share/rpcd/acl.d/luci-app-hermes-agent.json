{
	"luci-app-hermes-agent": {
		"description": "Grant access for luci-app-hermes-agent",
		"read": {
			"uci": [ "hermes" ],
			"ubus": {
				"session": [ "access", "login" ],
				"service": [ "list" ],
				"file": [ "exec", "read", "stat" ]
			},
			"file": {
				"/usr/share/hermes/luci-helper": [ "exec" ],
				"/etc/init.d/hermes": [ "exec" ],
				"/usr/share/hermes/VERSION": [ "read" ],
				"/tmp/hermes-setup.log": [ "read" ],
				"/tmp/hermes-setup.exit": [ "read" ]
			}
		},
		"write": {
			"uci": [ "hermes" ],
			"ubus": {
				"file": [ "exec" ]
			},
			"file": {
				"/usr/share/hermes/luci-helper": [ "exec" ],
				"/etc/init.d/hermes": [ "exec" ]
			}
		}
	}
}
